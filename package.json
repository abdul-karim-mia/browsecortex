{
  "name": "browsecortex",
  "version": "1.0.0",
  "private": true,
  "description": "Open source AI browser assistant — Chrome extension, bring your own AI provider, full browser control.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
