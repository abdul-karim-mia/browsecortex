{
  "name": "browsecortex",
  "version": "1.0.3",
  "private": true,
  "description": "Open source AI browser assistant — Chrome extension, bring your own AI provider, full browser control.",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "release": "scripts/release.sh",
    "release:major": "scripts/release.sh major",
    "release:minor": "scripts/release.sh minor",
    "release:patch": "scripts/release.sh patch"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
